Q# Copy to .env and fill in real values. See config.py for the full list
# of settings and their defaults — this file only lists what you
# actually need to set for local development.

ENV=development

# --- Google OAuth (from Google Cloud Console) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Cookie signing ---
# Any long random string for local dev. Must be overridden with a real
# secret before production — app refuses to boot on the default value.
COOKIE_SIGNING_SECRET=dev-only-insecure-secret-change-me

# --- LLM provider (optional at boot; ai/ calls degrade without it) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- GitHub API (optional; used for candidate profile GitHub sync) ---
GITHUB_API_TOKEN=

# --- Database (defaults to a local SQLite file if unset) ---
DATABASE_URL=sqlite:///./cerno.db
